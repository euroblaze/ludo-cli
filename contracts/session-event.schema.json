{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LUDO Contract B — session event (v2)",
  "description": "Agent -> gateway event envelope on NATS (ludo.events.<session_id>). The gateway projects these into client SSE. Shared seam; mirror of ludo-apps backend/contract.",
  "type": "object",
  "required": ["session_id", "type", "payload", "at", "schema_version", "checkpoint_required"],
  "additionalProperties": true,
  "properties": {
    "session_id": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "session_started", "session_end",
        "model_started", "model_completed",
        "job_started", "job_completed", "job_failed",
        "turn_started", "turn_completed",
        "safety_event", "checkpoint_requested"
      ]
    },
    "payload": { "type": "object" },
    "at": { "type": "string", "format": "date-time" },
    "schema_version": { "type": "string" },
    "checkpoint_required": { "type": "boolean" }
  }
}
